{
  "name": "static-to-variable-monorepo",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo dev --filter=@static-to-variable/web",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "release": "turbo build --filter=static-to-variable && changeset publish",
    "pipeline": "npm --workspace static-to-variable run cli --",
    "pipeline:list": "npm --workspace static-to-variable run cli -- list",
    "pipeline:status": "npm --workspace static-to-variable run cli -- status",
    "setup:python": "uv sync",
    "build:example": "uv run python -m variable_gen.cli build --config examples/minimal/stv.config.json --style all",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "lefthook": "^2.1.10",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "portless": "^0.15.1",
    "turbo": "^2",
    "ultracite": "^7.9.3",
    "vitest": "^4.1.10"
  },
  "packageManager": "npm@11.16.0"
}
