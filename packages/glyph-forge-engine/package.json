{
  "name": "@static-to-variable/glyph-forge-engine",
  "version": "0.0.0",
  "private": true,
  "description": "Python SVG renderer + broken-glyph manifest feeding the @static-to-variable/studio audit UI.",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "ingest": "../../.venv/bin/python python/ingest_audit_reports.py",
    "render": "../../.venv/bin/python python/render_glyph.py",
    "cache": "../../.venv/bin/python python/build_cache.py",
    "score": "../../.venv/bin/python python/build_scores.py",
    "recommend": "../../.venv/bin/python python/recommend_strategy.py",
    "solve": "../../.venv/bin/python python/solve_glyph.py",
    "apply": "../../.venv/bin/python python/apply_pending_triage.py",
    "bulk-stage": "../../.venv/bin/python python/bulk_stage.py",
    "auto-stage": "../../.venv/bin/python python/bulk_stage.py --strategy-source suggestion --no-downgrade",
    "reconstruction-stage": "../../.venv/bin/python python/bulk_stage.py --reconstruction-review",
    "converge": "../../.venv/bin/python python/converge.py",
    "build": "tsc --noEmit",
    "qa:build": "npm run ingest && npm run cache -- --force && npm run score && npm run recommend && npm run solve"
  }
}
